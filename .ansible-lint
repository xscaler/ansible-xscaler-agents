---
profile: min
exclude_paths:
  - test/output/
  - collections/
  - .github/
skip_list:
  # Project vars are intentionally global (xscaler_*),
  # not role-prefixed — they're shared across roles via group_vars.
  - var-naming[no-role-prefix]
  # Some smoke checks intentionally use service CLIs.
  - command-instead-of-module
