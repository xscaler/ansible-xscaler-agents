---
extends: relaxed
rules:
  line-length:
    max: 200
    level: warning
  truthy:
    allowed-values: ["true", "false"]
    check-keys: false   # allow GitHub Actions' `on:` key
  comments:
    min-spaces-from-content: 1
  octal-values:
    forbid-implicit-octal: true
    forbid-explicit-octal: true
ignore: |
  test/output/
  collections/
