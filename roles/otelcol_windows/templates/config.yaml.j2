# {{ ansible_managed }}
# xScaler otel agent — Windows host.
receivers:
{% if signals.metrics %}
  hostmetrics:
    collection_interval: {{ otelcol_windows_collection_interval }}
    scrapers:
      cpu: {}
      memory: {}
      disk: {}
      filesystem: {}
      network: {}
      paging: {}
      processes: {}
{% endif %}
{% if signals.logs %}
{% for ch in otelcol_windows_eventlog_channels %}
  windowseventlog/{{ ch | lower }}:
    channel: {{ ch }}
{% endfor %}
{% endif %}
{% if signals.traces %}
  otlp:
    protocols:
      grpc:
        endpoint: {{ otelcol_windows_otlp_grpc_endpoint }}
      http:
        endpoint: {{ otelcol_windows_otlp_http_endpoint }}
{% endif %}

processors:
  memory_limiter:
    check_interval: 5s
    limit_mib: {{ otelcol_windows_memory_limit_mib }}
  batch:
    timeout: 5s
    send_batch_size: 1024
  resourcedetection:
    detectors: [env, system]
    system:
      hostname_sources: [os]

exporters:
{% if signals.metrics %}
  otlphttp/metrics:
    metrics_endpoint: "{{ xscaler_metrics_endpoint }}"
    headers:
      Authorization: "Bearer {{ xscaler_api_key }}"
      X-Scope-OrgID: "{{ xscaler_org_id }}"
{% endif %}
{% if signals.logs %}
  otlphttp/logs:
    logs_endpoint: "{{ xscaler_logs_endpoint }}"
    headers:
      Authorization: "Bearer {{ xscaler_api_key }}"
      X-Scope-OrgID: "{{ xscaler_org_id }}"
{% endif %}
{% if signals.traces %}
  otlphttp/traces:
    traces_endpoint: "{{ xscaler_traces_endpoint }}"
    headers:
      Authorization: "Bearer {{ xscaler_api_key }}"
      X-Scope-OrgID: "{{ xscaler_org_id }}"
{% endif %}

service:
  pipelines:
{% if signals.metrics %}
    metrics:
      receivers: [hostmetrics]
      processors: [memory_limiter, resourcedetection, batch]
      exporters: [otlphttp/metrics]
{% endif %}
{% if signals.logs %}
    logs:
      receivers: [{% for ch in otelcol_windows_eventlog_channels %}windowseventlog/{{ ch | lower }}{{ ", " if not loop.last else "" }}{% endfor %}]
      processors: [memory_limiter, resourcedetection, batch]
      exporters: [otlphttp/logs]
{% endif %}
{% if signals.traces %}
    traces:
      receivers: [otlp]
      processors: [memory_limiter, resourcedetection, batch]
      exporters: [otlphttp/traces]
{% endif %}
  telemetry:
    logs:
      level: info
