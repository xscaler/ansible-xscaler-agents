# {{ ansible_managed }}
# xScaler otel agent — network-telemetry collector.
#   SNMP polling -> metrics;  NetFlow/sFlow/IPFIX -> logs.
receivers:
{% if signals.metrics %}
{% for t in snmp_targets %}
  snmp/{{ t.name }}:
    collection_interval: {{ t.collection_interval | default('60s') }}
    endpoint: "{{ t.endpoint }}"
    version: {{ t.version | default('v2c') }}
{% if (t.version | default('v2c')) in ['v1', 'v2c'] %}
    community: "{{ t.community | default('public') }}"
{% else %}
    security_level: {{ t.security_level | default('auth_priv') }}
    user: "{{ t.user }}"
    auth_type: "{{ t.auth_type | default('SHA') }}"
    auth_password: "{{ t.auth_password }}"
    privacy_type: "{{ t.privacy_type | default('AES') }}"
    privacy_password: "{{ t.privacy_password }}"
{% endif %}
{{ snmp_metrics | indent(4, true) }}
{% endfor %}
{% endif %}
{% if signals.logs %}
{% for l in flow_listeners %}
  netflow/{{ l.scheme }}{{ l.port }}:
    scheme: {{ l.scheme }}
    port: {{ l.port }}
    sockets: {{ l.sockets | default(16) }}
    workers: {{ l.workers | default(32) }}
{% endfor %}
{% endif %}

processors:
  memory_limiter:
    check_interval: 5s
    limit_mib: {{ otelcol_nc_memory_limit_mib }}
  batch:
    timeout: 5s
    send_batch_size: 1024
  resourcedetection:
    detectors: [env, system]
    system:
      hostname_sources: [os]

exporters:
{% if signals.metrics %}
  otlphttp/metrics:
    metrics_endpoint: "{{ xscaler_metrics_endpoint }}"
    headers:
      Authorization: "Bearer {{ xscaler_api_key }}"
      X-Scope-OrgID: "{{ xscaler_org_id }}"
{% endif %}
{% if signals.logs %}
  otlphttp/logs:
    logs_endpoint: "{{ xscaler_logs_endpoint }}"
    headers:
      Authorization: "Bearer {{ xscaler_api_key }}"
      X-Scope-OrgID: "{{ xscaler_org_id }}"
{% endif %}

service:
  pipelines:
{% if signals.metrics and snmp_targets | length > 0 %}
    metrics:
      receivers: [{% for t in snmp_targets %}snmp/{{ t.name }}{{ ", " if not loop.last else "" }}{% endfor %}]
      processors: [memory_limiter, resourcedetection, batch]
      exporters: [otlphttp/metrics]
{% endif %}
{% if signals.logs and flow_listeners | length > 0 %}
    logs:
      receivers: [{% for l in flow_listeners %}netflow/{{ l.scheme }}{{ l.port }}{{ ", " if not loop.last else "" }}{% endfor %}]
      processors: [memory_limiter, batch]
      exporters: [otlphttp/logs]
{% endif %}
  telemetry:
    logs:
      level: info
